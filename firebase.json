{
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log"
            ]
        }
    ],
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "functions/**",
            ".git/**",
            ".firebase/**",
            ".vscode/**",
            "firebase-debug.log",
            "**/*.md",
            "**/*.log",
            ".firebaserc",
            "firestore.rules",
            "storage.rules",
            "package.json",
            "package-lock.json",
            "upload-mock-data.js",
            "repair_js.js",
            "dark_mode_migrate.js",
            "dark_mode_migrate_html.js",
            "scripts/**",
            "storage-*.json",
            "hosting-*.json",
            "logo.png",
            "logo_dark.png",
            "logo_light.png",
            "images/bg-3d.png",
            "images/bg-3d-premium.png"
        ],
        "redirects": [
            {
                "source": "/html",
                "destination": "/index.html",
                "type": 301
            },
            {
                "source": "/html/",
                "destination": "/index.html",
                "type": 301
            },
            {
                "source": "/html/index.html",
                "destination": "/index.html",
                "type": 301
            },
            {
                "source": "/mock-tests.html",
                "destination": "/html/mock-tests.html",
                "type": 301
            },
            {
                "source": "/free-test",
                "destination": "/html/mock-tests.html",
                "type": 301
            },
            {
                "source": "/free-tests",
                "destination": "/html/mock-tests.html",
                "type": 301
            },
            {
                "source": "/view-all-free-tests",
                "destination": "/html/mock-tests.html",
                "type": 301
            }
        ],
        "headers": [
            {
                "source": "**",
                "headers": [
                    {
                        "key": "X-Content-Type-Options",
                        "value": "nosniff"
                    },
                    {
                        "key": "X-Frame-Options",
                        "value": "DENY"
                    },
                    {
                        "key": "Referrer-Policy",
                        "value": "strict-origin-when-cross-origin"
                    },
                    {
                        "key": "Permissions-Policy",
                        "value": "camera=(), microphone=(), geolocation=(), payment=*"
                    },
                    {
                        "key": "Strict-Transport-Security",
                        "value": "max-age=31536000; includeSubDomains; preload"
                    }
                ]
            },
            {
                "source": "**/*.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache"
                    },
                    {
                        "key": "Content-Security-Policy",
                        "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.gstatic.com https://*.cloudfunctions.net https://api.razorpay.com https://checkout.razorpay.com https://*.razorpay.com; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdnjs.cloudflare.com https://checkout.razorpay.com https://*.razorpay.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; frame-src https://accounts.google.com https://checkout.razorpay.com https://api.razorpay.com https://*.razorpay.com https://*.firebaseapp.com https://apis.google.com; media-src 'self' blob: https:;"
                    }
                ]
            },
            {
                "source": "/",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache"
                    },
                    {
                        "key": "Content-Security-Policy",
                        "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.gstatic.com https://*.cloudfunctions.net https://api.razorpay.com https://checkout.razorpay.com https://*.razorpay.com; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdnjs.cloudflare.com https://checkout.razorpay.com https://*.razorpay.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; frame-src https://accounts.google.com https://checkout.razorpay.com https://api.razorpay.com https://*.razorpay.com https://*.firebaseapp.com https://apis.google.com; media-src 'self' blob: https:;"
                    }
                ]
            },
            {
                "source": "**/*.css",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=3600"
                    }
                ]
            },
            {
                "source": "**/*.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=3600"
                    }
                ]
            },
            {
                "source": "**/*.{png,jpg,jpeg,gif,svg,webp,ico,woff,woff2}",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=2592000"
                    }
                ]
            }
        ]
    }
}
